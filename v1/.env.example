# Upstash REST endpoint (no trailing slash)
UPSTASH_REDIS_REST_URL=https://guided-spider-19708.upstash.io

# Keep read token optional for local read test
UPSTASH_REDIS_REST_TOKEN_READ=your_read_token

# Required for writing updates
UPSTASH_REDIS_REST_TOKEN_WRITE=your_write_token

# Optional: free Coinalyze API key for 7D liquidation metrics (recommended)
# Generate at: https://coinalyze.net/account/api-key/
COINALYZE_API_KEY=

# Optional comma-separated symbols for liquidation history
# Default: BTCUSDT_PERP.A,ETHUSDT_PERP.A
COINALYZE_LIQ_SYMBOLS=BTCUSDT_PERP.A,ETHUSDT_PERP.A

# Optional: major exchanges no-key liquidation probe (Binance/Hyperliquid)
# 目前僅回傳可用性與限制說明，不會輸出不可靠的清算總額。

# Note: V1 評估會在每次執行 update:data 時自動重算並覆蓋寫回。

# V1 不輸出/不部署本地 latest.json；所有資料以 Upstash 為準
