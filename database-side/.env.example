# Coinglass Open API v4
COINGLASS_API_BASE=https://open-api-v4.coinglass.com
COINGLASS_API_KEY=your_coinglass_api_key

# Upstash REST
UPSTASH_REDIS_REST_URL=https://your-upstash.upstash.io
UPSTASH_REDIS_REST_TOKEN_READ=your_read_token
UPSTASH_REDIS_REST_TOKEN_WRITE=your_write_token

# Upstash keys for the new database-side program
DATABASE_SIDE_UPSTASH_KEY=cryptopulse:database:coinglass:derivatives
DATABASE_SIDE_UPSTASH_LAST_UPDATED_KEY=cryptopulse:database:coinglass:last_updated

# Optional controls
DATABASE_SIDE_SERIES_LIMIT=400
DATABASE_SIDE_FETCH_LIMIT=200
DATABASE_SIDE_LOOP_MINUTES=30
